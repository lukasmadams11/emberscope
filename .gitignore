# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ---- editor configs ----
.vscode/
.idea/
*.iml
.project
.classpath
.settings/

# ---- node / npm (only if you add a local dev server later) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn/

# ---- python (if you ever add tooling) ----
__pycache__/
*.py[cod]
.venv/
venv/

# ---- env / secrets ----
.env
.env.local
.env.*.local
*.pem
*.key

# ---- build outputs (not needed yet but future-proofing) ----
dist/
build/
.cache/
.parcel-cache/

# ---- Claude scratch / local-only files ----
.claude/
outputs/
*.log
